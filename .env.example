# content-engine — environment for the Node adapters + live tests.
#
# Copy to .env and fill in your key:   cp .env.example .env
#
# Where it's read:
#   - `npm run test:live`  loads .env automatically (vitest.live.config.ts).
#   - `createNodeEngine({})` falls back to OPENROUTER_API_KEY if you don't pass openRouterApiKey.
#   - For your own scripts:  npx tsx --env-file=.env your-script.ts   (Node 22+)
#
# The hermetic suite (`npm test` / `npm run verify`) needs NONE of this — it runs on fakes.

# OpenRouter API key — required for any real LLM call / the OpenRouter live test.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional OpenRouter attribution headers (appear on your OpenRouter dashboard).
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=content-engine

# Set to 1 to enable the live Playwright browser test.
# Requires a browser binary first:  npx playwright install chromium
RUN_BROWSER_TESTS=

# NOTE: model routing is config-as-data, not env. Override per role in code:
#   createNodeEngine({ config: { models: { paint: "...", critique: "..." } } })
# Defaults live in src/config/models.ts.
